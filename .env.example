
# ──── Database (local docker-compose) ────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=llm_lab
# Full URL (optional). If unset, backend uses POSTGRES_* above when using compose.
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ──── Auth ────
SECRET_KEY=generate-a-long-random-secret-key

# ──── HuggingFace Local Model (CPU) ────
HF_MODEL_NAME=google/flan-t5-small
